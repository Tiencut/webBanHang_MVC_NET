@model SV22T1020761.Models.Sales.OrderViewInfo
@{
    ViewData["Title"] = "Chi ti?t ūűn hŗng";
}

<h3>@ViewData["Title"] - @Model.OrderID</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">M? ūűn</dt>
        <dd class="col-sm-10">@Model.OrderID</dd>

        <dt class="col-sm-2">Th?i gian</dt>
        <dd class="col-sm-10">@Model.OrderTime</dd>

        <dt class="col-sm-2">KhŠch hŗng</dt>
        <dd class="col-sm-10">@Model.CustomerName</dd>

        <dt class="col-sm-2">–?a ch?</dt>
        <dd class="col-sm-10">@Model.DeliveryAddress, @Model.DeliveryProvince</dd>

        <dt class="col-sm-2">T?ng</dt>
        <dd class="col-sm-10">@Model.TotalAmount</dd>

        <dt class="col-sm-2">Tr?ng thŠi</dt>
        <dd class="col-sm-10">@Model.Status</dd>
    </dl>
</div>

<div>
    <h4>Chi ti?t hŗng</h4>
    @{ var details = ViewBag.Details as System.Collections.Generic.List<SV22T1020761.Models.Sales.OrderDetailViewInfo>; }
    @if (details != null && details.Count > 0)
    {
        <table class="table">
            <thead><tr><th>S?n ph?m</th><th>S? lż?ng</th><th>–űn giŠ</th><th>Thŗnh ti?n</th></tr></thead>
            <tbody>
                @foreach(var d in details)
                {
                    <tr>
                        <td>@d.ProductName</td>
                        <td>@d.Quantity</td>
                        <td>@d.SalePrice</td>
                        <td>@d.TotalPrice</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning">KhŰng ců chi ti?t ūűn hŗng</div>
    }
</div>

<div>
    <a asp-controller="Orders" asp-action="Index" class="btn btn-secondary">Quay l?i</a>
</div>