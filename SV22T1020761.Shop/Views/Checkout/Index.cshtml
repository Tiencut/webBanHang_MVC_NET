@{
    ViewData["Title"] = "Checkout";
}

<h3>Checkout</h3>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Place" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="mb-3">
                <label class="form-label">T?nh/Thành</label>
                <input name="deliveryProvince" class="form-control" placeholder="Ví d?: Hà N?i" autofocus />
                <span class="form-help">Ch?n t?nh/thành ð? tính phí v?n chuy?n.</span>
            </div>
            <div class="mb-3">
                <label class="form-label">Ð?a ch?</label>
                <input name="deliveryAddress" class="form-control" placeholder="S? nhà, ðý?ng, phý?ng/qu?n" />
            </div>
            <button class="btn btn-success">Ð?t hàng</button>
        </form>
    </div>
    <div class="col-md-6">
        <h5>Tóm t?t gi? hàng</h5>
        <div id="checkoutCart">
            @{
                var summary = ViewBag.Summary as (int Count, decimal Total)?;
                var cart = ViewBag.Cart as System.Collections.Generic.List<SV22T1020761.Shop.AppCodes.CartItem>;
            }
            @if (cart != null && cart.Count>0)
            {
                <table class="table">
                    <thead><tr><th>S?n ph?m</th><th>S? lý?ng</th><th>Giá</th><th>Thành ti?n</th></tr></thead>
                    <tbody>
                        @foreach(var it in cart)
                        {
                            <tr>
                                <td>@it.ProductName</td>
                                <td>@it.Qty</td>
                                <td>@it.Price</td>
                                <td>@(it.Price*it.Qty)</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <p>T?ng: @summary?.Total</p>
            }
            else
            {
                <div class="alert alert-warning">Gi? hàng tr?ng</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var form = document.querySelector('form[asp-action="Place"]');
            form?.addEventListener('submit', function () {
                setTimeout(function(){ window.focusFirstInvalid && window.focusFirstInvalid(); }, 50);
            });
        });
    </script>
}
