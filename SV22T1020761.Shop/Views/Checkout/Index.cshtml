@{
    ViewData["Title"] = "Checkout";
}

<h3>Checkout</h3>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Place" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">T?nh/Thýnh</label>
                <input name="deliveryProvince" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">–?a ch?</label>
                <input name="deliveryAddress" class="form-control" />
            </div>
            <button class="btn btn-success">–?t hýng</button>
        </form>
    </div>
    <div class="col-md-6">
        <h5>TÛm t?t gi? hýng</h5>
        <div id="checkoutCart">
            @{
                var summary = ViewBag.Summary as (int Count, decimal Total)?;
                var cart = ViewBag.Cart as System.Collections.Generic.List<SV22T1020761.Shop.AppCodes.CartItem>;
            }
            @if (cart != null && cart.Count>0)
            {
                <table class="table">
                    <thead><tr><th>S?n ph?m</th><th>S? l˝?ng</th><th>Gi·</th><th>Thýnh ti?n</th></tr></thead>
                    <tbody>
                        @foreach(var it in cart)
                        {
                            <tr>
                                <td>@it.ProductName</td>
                                <td>@it.Qty</td>
                                <td>@it.Price</td>
                                <td>@(it.Price*it.Qty)</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <p>T?ng: @summary?.Total</p>
            }
            else
            {
                <div class="alert alert-warning">Gi? hýng tr?ng</div>
            }
        </div>
    </div>
</div>
