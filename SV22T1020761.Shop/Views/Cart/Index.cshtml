@model System.Collections.Generic.List<SV22T1020761.Shop.AppCodes.CartItem>
@{
    ViewData["Title"] = "Gi? hąng";
}

<h3>@ViewData["Title"]</h3>

<div id="cartTableContainer">
    @Html.Partial("_CartTable", Model)
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var container = document.getElementById('cartTableContainer');
            container.addEventListener('submit', async function (e) {
                e.preventDefault();
                var form = e.target;
                var fd = new FormData(form);
                try {
                    var res = await fetch(form.action, { method: form.method, body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (res.ok) {
                        var html = await res.text();
                        container.innerHTML = html;
                        showToast('C?p nh?t gi? hąng', 'success');
                    } else showToast('L?i', 'error');
                } catch (err) { showToast(err.message, 'error'); }
            });
        });
    </script>
}