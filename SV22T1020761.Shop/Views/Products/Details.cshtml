@model SV22T1020761.Models.Catalog.ProductDetailsViewModel
@{
    ViewData["Title"] = "Chi ti?t s?n ph?m";
}
<div class="container">
    <div class="product-details">
        <div class="row">
            <div class="col-md-6">
                @if (Model.Photos != null && Model.Photos.Count > 0)
                {
                    <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            @for (int i = 0; i < Model.Photos.Count; i++)
                            {
                                var p = Model.Photos[i];
                                <div class="carousel-item @(i==0?"active":"")">
                                    <img src="@Url.Content("~/admin-images/products/" + p.Photo)" class="d-block w-100" alt="@p.Description" onerror="this.onerror=null;this.src='@Url.Content("~/admin-images/products/nophoto.png")'" />
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                }
                else
                {
                    <img src="@Url.Content("~/admin-images/products/" + (Model.Product.Photo ?? "nophoto.png"))" class="img-fluid" onerror="this.onerror=null;this.src='@Url.Content("~/admin-images/products/nophoto.png")'" />
                }
            </div>
            <div class="col-md-6">
                <h2>@Model.Product.ProductName</h2>
                <p class="text-muted">@Model.Product.ProductDescription</p>
                <p><strong>Giá:</strong> <span class="text-primary">@Model.Product.Price.ToString("C")</span></p>
                <p><strong>Đőn v?:</strong> @Model.Product.Unit</p>
                <p><strong>Kho:</strong> @Model.Product.Quantity</p>
                @if (!string.IsNullOrEmpty(Model.CategoryName)) { <p><strong>Lo?i:</strong> @Model.CategoryName</p> }
                @if (!string.IsNullOrEmpty(Model.SupplierName)) { <p><strong>Nhŕ cung c?p:</strong> @Model.SupplierName</p> }

                <form id="formAddToCart" method="post" asp-controller="Cart" asp-action="Add">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Product.ProductID" />
                    <div class="input-group mb-3" style="max-width:200px;">
                        <input type="number" name="qty" value="1" min="1" class="form-control" />
                        <button class="btn btn-success">Thęm vŕo gi?</button>
                    </div>
                </form>

                @if (Model.Attributes != null && Model.Attributes.Count > 0)
                {
                    <h5>Thông s? k? thu?t</h5>
                    <table class="table table-sm">
                        <tbody>
                            @foreach(var a in Model.Attributes)
                            {
                                <tr>
                                    <td style="width:35%">@a.AttributeName</td>
                                    <td>@Html.Raw(a.AttributeValue)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var form = document.getElementById('formAddToCart');
            form?.addEventListener('submit', async function (e) {
                e.preventDefault();
                var fd = new FormData(form);
                try {
                    var res = await fetch(form.action, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    if (res.ok) {
                        var html = await res.text();
                        var el = document.getElementById('cartSummary');
                        if (el) el.innerHTML = html;
                        showToast('Đ? thęm vŕo gi?', 'success');
                    } else {
                        showToast('L?i khi thęm vŕo gi?', 'error');
                    }
                } catch (err) { showToast('L?i: ' + err.message, 'error'); }
            });
        });
    </script>
}