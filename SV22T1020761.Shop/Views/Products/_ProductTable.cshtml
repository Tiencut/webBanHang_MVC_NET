@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Catalog.Product>

<table class="table table-bordered table-hover mb-0">
    <thead class="table-secondary">
        <tr>
            <th>TÍn</th>
            <th>Gi·</th>
            <th>S? l˝?ng</th>
            <th class="text-center">Thao t·c</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.DataItems != null && Model.DataItems.Count > 0)
        {
            foreach (var p in Model.DataItems)
            {
                <tr>
                    <td>@p.ProductName</td>
                    <td>@p.Price</td>
                    <td>@p.Quantity</td>
                    <td class="text-center">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductID" class="btn btn-sm btn-primary">Xem</a>
                        <form class="d-inline" method="post" asp-controller="Cart" asp-action="Add">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@p.ProductID" />
                            <input type="hidden" name="qty" value="1" />
                            <button class="btn btn-sm btn-success">ThÍm</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="4" class="text-center">KhÙng cÛ d? li?u</td></tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" href="#" data-page="@i">@i</a></li>
        }
    </ul>
</nav>