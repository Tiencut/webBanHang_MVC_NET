@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Catalog.Product>
@{
    ViewData["Title"] = "Home";
}

<div class="bg-light py-5 mb-4">
    <div class="container text-center">
        <h1 class="display-5 fw-bold">Chào mừng đến với SV22T1020761 Shop</h1>
        <p class="lead text-muted">Mua sắm nhanh chóng — sản phẩm đa dạng, giao hàng tận nơi.</p>
        <p class="mt-3">
            <a class="btn btn-primary btn-lg" asp-controller="Products" asp-action="Index">Xem tất cả sản phẩm</a>
            <a class="btn btn-outline-secondary btn-lg ms-2" asp-controller="Cart" asp-action="Index">Xem giỏ hàng (@(ViewBag.CartCount ?? 0))</a>
        </p>
    </div>
</div>

<div class="container">
    <div class="row mb-4">
        <div class="col-md-4 text-center">
            <h5>Chất lượng đảm bảo</h5>
            <p class="text-muted">Sản phẩm được kiểm định trước khi giao.</p>
        </div>
        <div class="col-md-4 text-center">
            <h5>Giao hàng nhanh</h5>
            <p class="text-muted">Vận chuyển toàn quốc, theo dõi đơn hàng dễ dàng.</p>
        </div>
        <div class="col-md-4 text-center">
            <h5>Hỗ trợ 24/7</h5>
            <p class="text-muted">Tư vấn và hỗ trợ khách hàng mọi lúc.</p>
        </div>
    </div>

    <h4 class="mb-3">Sản phẩm nổi bật</h4>
    <div id="homeFeatured">
        @Html.Partial("_ProductGrid", Model)
    </div>
</div>

@section Scripts {
    <script>
        // Optionally add small animation or lazyload in future
    </script>
}
