@model SV22T1020761.Models.Shipper
@{
    ViewBag.Title = "Xóa Người giao hàng";
}
<h2>Xóa Người giao hàng</h2>
<h3>Bạn có chắc chắn muốn xóa người giao hàng này?</h3>
<div>
    <h4>@Model.ShipperName</h4>
    <p>@Model.Phone</p>
</div>
<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="ShipperID" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
