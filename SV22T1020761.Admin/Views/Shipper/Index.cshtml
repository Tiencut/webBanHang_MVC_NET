@model IEnumerable<SV22T1020761.Models.Shipper>
@{
    ViewBag.Title = "Danh sách Người giao hàng";
}
<h2>Danh sách Người giao hàng</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Tên Người giao hàng</th>
            <th>Số điện thoại</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ShipperName</td>
                <td>@item.Phone</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ShipperID" class="btn btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.ShipperID" class="btn btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
