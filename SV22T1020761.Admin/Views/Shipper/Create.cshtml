@model SV22T1020761.Models.Shipper

@{
    ViewBag.Title = "Thêm Người giao hàng";
}

<h2>Thêm Người giao hàng</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label for="ShipperName">Tên Người giao hàng</label>
        <input asp-for="ShipperName" class="form-control" />
        <span asp-validation-for="ShipperName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label for="Phone">Số điện thoại</label>
        <input asp-for="Phone" class="form-control" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
