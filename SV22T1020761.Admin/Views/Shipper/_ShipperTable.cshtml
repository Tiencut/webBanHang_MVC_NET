@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Shipper>

<table class="table table-bordered table-hover mb-0">
    <thead class="table-secondary">
        <tr>
            <th>TÍn ng˝?i giao h‡ng</th>
            <th>–i?n tho?i</th>
            <th class="text-center" style="width:100px;">Thao t·c</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.DataItems != null && Model.DataItems.Count > 0)
        {
            foreach (var item in Model.DataItems)
            {
                <tr>
                    <td>@item.ShipperName</td>
                    <td>@item.Phone</td>
                    <td class="text-center text-nowrap">
                        <a href="#" class="btn btn-sm btn-primary open-modal"
                            data-url="@Url.Action("Form","Shipper", new { id = item.ShipperID })">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-danger open-modal"
                            data-url="@Url.Action("Form","Shipper", new { id = item.ShipperID })?delete=true">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="3" class="text-center">KhÙng cÛ d? li?u</td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }
    </ul>
</nav>