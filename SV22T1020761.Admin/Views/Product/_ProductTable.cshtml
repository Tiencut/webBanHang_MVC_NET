@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Catalog.Product>

@if (Model != null && Model.PageCount > 1)
{
    <table class="table table-bordered table-hover mb-0">
        <thead class="table-secondary">
            <tr>
                <th class="text-center" style="width:80px;">Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th class="text-center" style="width:100px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.DataItems != null && Model.DataItems.Count > 0)
            {
                foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@Url.Content("~/images/products/" + (item.Photo ?? "nophoto.png"))" 
                                 style="height:50px; width:50px; object-fit:cover; border-radius:4px;" 
                                 alt="@item.ProductName"
                                 onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2250%22 height=%2250%22%3E%3Crect fill=%22%23ddd%22 width=%2250%22 height=%2250%22/%3E%3Ctext x=%2225%22 y=%2225%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%23999%22 font-size=%2212%22%3ENo Image%3C/text%3E%3C/svg%3E'" />
                        </td>
                        <td>@item.ProductName</td>
                        <td>@item.Price</td>
                        <td>@item.Quantity</td>
                        <td class="text-center text-nowrap">
                            <a href="@Url.Action("Edit","Product", new { id = item.ProductID })" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-danger open-modal" data-url="@Url.Action("Form","Product", new { id = item.ProductID, delete = true })">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>

    <ul class="pagination justify-content-center mt-3">
        @if (Model.PageCount > 1)
        {
            if (Model.Page > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="#" data-page="1">&laquo;</a>
                </li>
            }
            for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.PageCount, Model.Page + 2); i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="#" data-page="@i">@i</a>
                </li>
            }
            if (Model.Page < Model.PageCount)
            {
                <li class="page-item">
                    <a class="page-link" href="#" data-page="@Model.PageCount">&raquo;</a>
                </li>
            }
        }
    </ul>
}