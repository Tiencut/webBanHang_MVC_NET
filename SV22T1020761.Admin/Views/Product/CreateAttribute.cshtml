@model SV22T1020761.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Thêm thuộc tính";
    int productID = int.TryParse(Context.Request.Query["productId"], out int pid) ? pid : 
                    int.TryParse(Context.Request.RouteValues["id"]?.ToString(), out int rid) ? rid : 0;
}
@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-plus"></i>
        Thêm thuộc tính
    </button>

    <a href="~/Product/Edit/@productID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formCreate" method="post">

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Tên thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   required autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Giá trị thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">
                            Thứ tự hiển thị
                        </label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="1"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
