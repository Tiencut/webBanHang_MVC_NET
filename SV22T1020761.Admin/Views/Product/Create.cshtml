@model SV22T1020761.Models.Catalog.ProductDetailsViewModel
@{
    ViewBag.Title = "Thêm mới Sản phẩm";
}
<h2>Thêm mới Sản phẩm</h2>
<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label for="Product.ProductName">Tên sản phẩm *</label>
                <input asp-for="Product.ProductName" class="form-control" />
                <span asp-validation-for="Product.ProductName" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label for="Product.Price">Giá *</label>
                <input asp-for="Product.Price" class="form-control" />
                <span asp-validation-for="Product.Price" class="text-danger"></span>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label for="Product.ProductDescription">Mô tả sản phẩm</label>
                <textarea asp-for="Product.ProductDescription" class="form-control" rows="3"></textarea>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label for="Product.Unit">Đơn vị tính</label>
                <input asp-for="Product.Unit" class="form-control" placeholder="Ví dụ: cái, bộ, hộp..." />
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <label for="Product.SupplierID">Nhà cung cấp</label>
                <select asp-for="Product.SupplierID" class="form-control">
                    <option value="0">-- Chọn nhà cung cấp --</option>
                    @foreach (var supplier in ViewBag.Suppliers ?? new List<dynamic>())
                    {
                        <option value="@supplier.SupplierID">@supplier.SupplierName</option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label for="Product.CategoryID">Loại hàng</label>
                <select asp-for="Product.CategoryID" class="form-control">
                    <option value="0">-- Chọn loại hàng --</option>
                    @foreach (var category in ViewBag.Categories ?? new List<dynamic>())
                    {
                        <option value="@category.CategoryID">@category.CategoryName</option>
                    }
                </select>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label for="Product.Quantity">Số lượng tốn</label>
                <input asp-for="Product.Quantity" class="form-control" />
            </div>
        </div>
    </div>
    <div class="form-group">
        <div class="form-check">
            <input type="checkbox" asp-for="Product.IsSelling" class="form-check-input" />
            <label class="form-check-label" for="Product.IsSelling">Đang bán</label>
        </div>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>