@model SV22T1020761.Models.Catalog.ProductDetailsViewModel
@using System.Linq;
@{
    Layout = null;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="@Url.Action("CreateAttribute", "Product", new { id = Model.Product.ProductID })">
                            <i class="bi bi-plus"></i>
                            Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Attributes != null && Model.Attributes.Count > 0)
                        {
                            @foreach (var attr in Model.Attributes.OrderBy(x => x.DisplayOrder))
                            {
                                <tr>
                                    <td>@attr.AttributeName</td>
                                    <td>@attr.AttributeValue</td>
                                    <td class="text-center">@attr.DisplayOrder</td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="@Url.Action("EditAttribute", "Product", new { id = Model.Product.ProductID, attributeId = attr.AttributeID })">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="@Url.Action("DeleteAttribute", "Product", new { id = Model.Product.ProductID, attributeId = attr.AttributeID })">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">Chưa có thuộc tính nào. <a href="@Url.Action("CreateAttribute", "Product", new { id = Model.Product.ProductID })">Thêm thuộc tính</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
