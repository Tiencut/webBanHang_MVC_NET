@model PagedResult<SV22T1020761.Models.Catalog.Product>

@if (Model?.DataItems?.Count > 0)
{
    @foreach (var product in Model.DataItems)
    {
        <a href="#" class="list-group-item list-group-item-action product-item" 
           data-id="@product.ProductID" 
           data-name="@product.ProductName" 
           data-price="@product.Price"
           style="cursor: pointer;">
            <div class="row align-items-center">
                <div class="col-auto">
                    <img src="@Url.Content("~/images/products/" + (product.Photo ?? "nophoto.png"))" 
                         style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" />
                </div>
                <div class="col">
                    <div class="fw-bold">@product.ProductName</div>
                    <small class="text-muted">Giá: @product.Price.ToString("C0")</small>
                </div>
            </div>
        </a>
    }
}
else
{
    <div class="text-center text-muted py-3">
        Không có sản phẩm nào
    </div>
}
    }
}
else
{
    <div class="alert alert-info" role="alert">
        Không tìm thấy sản phẩm nào
    </div>
}

@* Pagination *@
@if (Model != null && Model.PageCount > 1)
{
    <div class="card-footer">
        <ul class="pagination justify-content-between mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link search-page-link" href="#" data-page="@(Model.Page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            <li class="page-item">
                <small class="form-text">Trang @Model.Page / @Model.PageCount</small>
            </li>
            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                <a class="page-link search-page-link" href="#" data-page="@(Model.Page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </div>
}
