@model SV22T1020761.Models.Sales.Order
@using SV22T1020761.Models.Sales
@{
    ViewBag.Title = "Xử lý Đơn hàng";
    TempData.Keep();
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="mb-3">
    <a href="~/Order/Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

<div class="card mb-3">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Đơn hàng #@Model.OrderID</h5>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <p><strong>Khách hàng:</strong> @Model.CustomerName</p>
                <p><strong>Ngày đặt:</strong> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Địa chỉ giao:</strong> @Model.DeliveryAddress, @Model.DeliveryProvince</p>
            </div>
            <div class="col-md-6">
                <p><strong>Trạng thái:</strong> 
                    <span class="badge @GetStatusBadgeClass(Model.Status)">
                        @GetStatusText(Model.Status)
                    </span>
                </p>
                <p><strong>Tổng tiền:</strong> <strong style="color: #d9534f;">@(Model.TotalAmount.HasValue ? Model.TotalAmount.Value.ToString("C0") : "0")</strong></p>
            </div>
        </div>

        <!-- Action Buttons Based on Status -->
        <div class="mb-3">
            @if (Model.Status == OrderStatusEnum.Draft)
            {
                <button type="button" class="btn btn-primary" onclick="setActionAndShowModal('New')">
                    <i class="bi bi-check-circle me-1"></i> Tạo mới đơn hàng
                </button>
            }
            else if (Model.Status == OrderStatusEnum.New)
            {
                <button type="button" class="btn btn-success" onclick="setActionAndShowModal('Accept')">
                    <i class="bi bi-check-lg me-1"></i> Duyệt đơn hàng
                </button>
                <button type="button" class="btn btn-danger" onclick="setActionAndShowModal('Reject')">
                    <i class="bi bi-x-lg me-1"></i> Từ chối
                </button>
                <button type="button" class="btn btn-warning" onclick="setActionAndShowModal('Cancel')">
                    <i class="bi bi-trash me-1"></i> Hủy
                </button>
            }
            else if (Model.Status == OrderStatusEnum.Accepted)
            {
                <button type="button" class="btn btn-info" onclick="setActionAndShowModal('Ship')">
                    <i class="bi bi-box-seam me-1"></i> Chuyển cho Shipper
                </button>
                <button type="button" class="btn btn-danger" onclick="setActionAndShowModal('Cancel')">
                    <i class="bi bi-trash me-1"></i> Hủy
                </button>
            }
            else if (Model.Status == OrderStatusEnum.Shipping)
            {
                <button type="button" class="btn btn-success" onclick="setActionAndShowModal('Complete')">
                    <i class="bi bi-check-circle me-1"></i> Hoàn tất
                </button>
            }
            else if (Model.Status == OrderStatusEnum.Completed || Model.Status == OrderStatusEnum.Cancelled || Model.Status == OrderStatusEnum.Rejected)
            {
                <p class="text-muted">Đơn hàng này không thể xử lý thêm.</p>
            }
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận hành động</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirmText"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="actionForm" method="post" action="@Url.Action("Edit", "Order", new { id = Model.OrderID })" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="actionInput" name="action" value="" />
                    <button type="submit" class="btn btn-primary" id="confirmBtn">Xác nhận</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    let confirmModal;
    
    // Initialize modal
    document.addEventListener('DOMContentLoaded', function() {
        confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        console.log('Modal initialized');
    });

    // Set action and show modal
    window.setActionAndShowModal = function(action) {
        console.log('Setting action:', action);
        const actionText = {
            'New': 'Tạo mới đơn hàng này?',
            'Accept': 'Duyệt và chấp nhận đơn hàng?',
            'Ship': 'Chuyển giao cho Shipper?',
            'Complete': 'Ghi nhận hoàn tất đơn hàng?',
            'Reject': 'Từ chối đơn hàng này?',
            'Cancel': 'Hủy đơn hàng này?'
        };
        const buttonText = {
            'New': 'Tạo mới',
            'Accept': 'Duyệt',
            'Ship': 'Chuyển',
            'Complete': 'Hoàn tất',
            'Reject': 'Từ chối',
            'Cancel': 'Hủy'
        };
        
        document.getElementById('confirmText').textContent = actionText[action] || 'Xác nhận hành động này?';
        document.getElementById('actionInput').value = action;
        document.getElementById('confirmBtn').textContent = buttonText[action] || 'Xác nhận';
        
        confirmModal.show();
    };

    // Log form submission
    document.getElementById('actionForm').addEventListener('submit', function(e) {
        const action = document.getElementById('actionInput').value;
        console.log('Submitting form with action:', action);
    });
</script>

@functions {
    private string GetStatusBadgeClass(OrderStatusEnum status)
    {
        return status switch
        {
            OrderStatusEnum.Draft => "bg-secondary",
            OrderStatusEnum.New => "bg-info",
            OrderStatusEnum.Accepted => "bg-primary",
            OrderStatusEnum.Shipping => "bg-warning",
            OrderStatusEnum.Completed => "bg-success",
            OrderStatusEnum.Cancelled => "bg-dark",
            OrderStatusEnum.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetStatusText(OrderStatusEnum status)
    {
        return status switch
        {
            OrderStatusEnum.Draft => "Nháp",
            OrderStatusEnum.New => "Mới",
            OrderStatusEnum.Accepted => "Đã duyệt",
            OrderStatusEnum.Shipping => "Đang giao",
            OrderStatusEnum.Completed => "Hoàn tất",
            OrderStatusEnum.Cancelled => "Bị hủy",
            OrderStatusEnum.Rejected => "Bị từ chối",
            _ => "Không xác định"
        };
    }
}