@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Sales.Order>
@{
    ViewBag.Title = "Quản lý Đơn hàng";
}
@section PageToolBar {
    <a href="~/Order/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Order/Index">
            <div class="input-group">
                <input type="text" name="searchValue" value="@Context.Request.Query["searchValue"]" class="form-control" placeholder="Mã đơn hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model?.RowCount ?? 0</strong> đơn hàng
</div>
<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Mã đơn hàng</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.DataItems != null && Model.DataItems.Count > 0)
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.OrderID</td>
                            <td>@item.CustomerName</td>
                            <td>@item.OrderDate</td>
                            <td>@item.TotalAmount</td>
                            <td class="text-center text-nowrap">
                                <a href="~/Order/Edit/@item.OrderID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Order/Delete/@item.OrderID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="?page=@i&searchValue=@Context.Request.Query["searchValue"]">@i</a>
            </li>
        }
    </ul>
</nav>