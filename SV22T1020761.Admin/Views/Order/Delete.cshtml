@model SV22T1020761.Models.Sales.Order
@{
    ViewBag.Title = "Xóa Đơn hàng";
}
<h2>Xóa Đơn hàng</h2>
<h3>Bạn có chắc chắn muốn xóa đơn hàng này?</h3>
<div>
    <h4>Khách hàng: @Model.CustomerName</h4>
    <p>Ngày đặt: @Model.OrderDate</p>
    <p>Tổng tiền: @Model.TotalAmount</p>
</div>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="OrderID" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
