@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Category>
@{
    ViewBag.Title = "Danh sách danh mục";
}
@section PageToolBar {
    <button id="btnCreateCategory" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Thêm mới
    </button>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="post" asp-action="Search" asp-controller="Category">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="text" name="SearchValue" value="@Context.Request.Query["searchValue"]" class="form-control" placeholder="Tên danh mục..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model?.RowCount ?? 0</strong> danh mục
</div>
<div class="card">
    <div class="card-body p-1">
        <div id="categoryTableContainer">
            @Html.Partial("_CategoryTable", Model)
        </div>
    </div>
</div>
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3" id="categoryPager">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }
    </ul>
</nav>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var form = document.getElementById('formSearch');
            var btnCreate = document.getElementById('btnCreateCategory');
            if (!form) return;
            async function doSearch(page) {
                var tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
                var token = tokenInput ? tokenInput.value : '';
                var data = new URLSearchParams(new FormData(form));
                if (page) data.set('Page', page);
                try {
                    var res = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest',
                            'Content-Type': 'application/x-www-form-urlencoded'
                        },
                        body: data.toString()
                    });
                    if (res.ok) {
                        var html = await res.text();
                        document.getElementById('categoryTableContainer').innerHTML = html;
                        var searchVal = form.querySelector('input[name="SearchValue"], input[name="searchValue"]')?.value || '';
                        var params = new URLSearchParams();
                        if (searchVal) params.set('searchValue', searchVal);
                        params.set('page', page || 1);
                        history.replaceState(null, '', window.location.pathname + '?' + params.toString());
                    } else {
                        showToast('Lỗi khi tìm kiếm.', 'error');
                    }
                } catch (err) {
                    showToast('Lỗi khi tìm kiếm: ' + err.message, 'error');
                }
            }
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                doSearch(1);
            });

            document.getElementById('categoryPager')?.addEventListener('click', function (e) {
                var target = e.target.closest('a[data-page]');
                if (!target) return;
                e.preventDefault();
                var page = target.getAttribute('data-page');
                doSearch(page);
            });

            btnCreate?.addEventListener('click', function () { openModal('@Url.Action("Form","Category")'); });

            async function openModal(url) {
                try {
                    var res = await fetch(url);
                    if (res.ok) {
                        var html = await res.text();
                        document.querySelector('#dialogModal .modal-content').innerHTML = html;
                        var modalEl = document.getElementById('dialogModal');
                        var modal = new bootstrap.Modal(modalEl);
                        modal.show();
                    }
                } catch (err) { console.error(err); showToast('Lỗi: ' + err.message, 'error'); }
            }

            // delegate clicks for modal open inside container
            document.getElementById('categoryTableContainer').addEventListener('click', function (e) {
                var btn = e.target.closest('.open-modal');
                if (btn) { e.preventDefault(); openModal(btn.getAttribute('data-url')); }
            });
        });
    </script>
}
