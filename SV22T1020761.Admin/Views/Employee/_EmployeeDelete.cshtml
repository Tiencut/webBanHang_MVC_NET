@model SV22T1020761.Models.HR.Employee
<div class="p-3">
    <h5>B?n cÛ ch?c ch?n mu?n xÛa nh‚n viÍn <strong>@Model.FullName</strong>?</h5>
    <form id="formEmployeeDelete" method="post" action="~/Employee/DeleteConfirmed">
        <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />
        <div class="text-end mt-3">
            <button type="submit" class="btn btn-danger">XÛa</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">H?y</button>
        </div>
    </form>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('formEmployeeDelete');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var url = form.action;
            var formData = new FormData(form);
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('employeeTableContainer').innerHTML = html;
                    var modalEl = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();
                } else {
                    alert('L?i khi xÛa');
                }
            } catch (err) {
                alert('L?i khi xÛa: ' + err.message);
            }
        });
    });
</script>