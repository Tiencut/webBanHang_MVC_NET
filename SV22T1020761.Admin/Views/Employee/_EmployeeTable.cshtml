@model PagedResult<SV22T1020761.Models.HR.Employee>

<table class="table table-bordered table-hover mb-0">
    <thead class="table-secondary">
        <tr>
            <th>TÍn nh‚n viÍn</th>
            <th>Ngýy sinh</th>
            <th>–i?n tho?i</th>
            <th>Email</th>
            <th>–?a ch?</th>
            <th class="text-center" style="width:120px;">Tr?ng th·i</th>
            <th class="text-center" style="width:100px;">Thao t·c</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.DataItems != null && Model.DataItems.Count > 0)
        {
            foreach (var item in Model.DataItems)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.Address</td>
                    <td class="text-center">
                        @if (item.IsWorking ?? false)
                        {
                            <span class="badge bg-success">–ang lým</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Ngh? vi?c</span>
                        }
                    </td>
                    <td class="text-center text-nowrap">
                        <a href="#" class="btn btn-sm btn-primary open-employee-modal" data-url="@Url.Action("Form","Employee", new { id = item.EmployeeID })">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-danger open-employee-modal" data-url="@Url.Action("Form","Employee", new { id = item.EmployeeID })?delete=true">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">KhÙng cÛ d? li?u</td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }
    </ul>
</nav>