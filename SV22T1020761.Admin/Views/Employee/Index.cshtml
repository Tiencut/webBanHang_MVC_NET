@model PagedResult<SV22T1020761.Models.HR.Employee>
@{
    ViewBag.Title = "Quản lý Nhân viên";
}
@section PageToolBar {
    <button id="btnCreateEmployee" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </button>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="searchForm" method="post" asp-action="Search" asp-controller="Employee">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="text" id="searchInput" name="SearchValue" value="@Context.Request.Query["searchValue"]" class="form-control" placeholder="Tên nhân viên..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model?.RowCount ?? 0</strong> nhân viên
</div>
<div id="employeeTableContainer">
    @Html.Partial("_EmployeeTable", Model)
</div>

@section Scripts {
    <script>
        // debounce helper
        function debounce(fn, delay) {
            var t;
            return function () {
                var args = arguments;
                clearTimeout(t);
                t = setTimeout(function () { fn.apply(null, args); }, delay);
            };
        }

        document.addEventListener('DOMContentLoaded', function () {
            var form = document.getElementById('searchForm');
            var input = document.getElementById('searchInput');
            var btnCreate = document.getElementById('btnCreateEmployee');

            async function doSearch(page) {
                var url = '@Url.Action("Search","Employee")';
                var data = new URLSearchParams(new FormData(form));
                if (page) data.set('Page', page);
                try {
                    var res = await fetch(url, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '', 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: data.toString()
                    });
                    if (res.ok) {
                        var html = await res.text();
                        document.getElementById('employeeTableContainer').innerHTML = html;
                        // update URL
                        var searchVal = form.querySelector('input[name="SearchValue"], input[name="searchValue"]')?.value || '';
                        var params = new URLSearchParams();
                        if (searchVal) params.set('searchValue', searchVal);
                        params.set('page', page || 1);
                        history.replaceState(null, '', window.location.pathname + '?' + params.toString());
                    }
                } catch (err) {
                    console.error(err);
                }
            }

            var debouncedSearch = debounce(function () { doSearch(1); }, 300);
            input.addEventListener('keyup', debouncedSearch);

            // delegate clicks for pager and action buttons inside container
            document.getElementById('employeeTableContainer').addEventListener('click', function (e) {
                var target = e.target.closest('a[data-page]');
                if (target) {
                    e.preventDefault();
                    var page = target.getAttribute('data-page');
                    doSearch(page);
                    return;
                }
                var btn = e.target.closest('.open-employee-modal');
                if (btn) {
                    e.preventDefault();
                    var url = btn.getAttribute('data-url');
                    openModal(url);
                }
            });

            btnCreate.addEventListener('click', function () {
                openModal('@Url.Action("Form","Employee")');
            });

            async function openModal(url) {
                try {
                    var res = await fetch(url);
                    if (res.ok) {
                        var html = await res.text();
                        document.querySelector('#dialogModal .modal-content').innerHTML = html;
                        var modalEl = document.getElementById('dialogModal');
                        var modal = new bootstrap.Modal(modalEl);
                        modal.show();
                    }
                } catch (err) { console.error(err); }
            }
        });
    </script>
}

