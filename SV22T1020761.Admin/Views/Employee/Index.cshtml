@model PagedResult<SV22T1020761.Models.Employee>
@{
    ViewBag.Title = "Quản lý Nhân viên";
}
@section PageToolBar {
    <a href="~/Employee/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="searchForm">
            <div class="input-group">
                <input type="text" name="SearchValue" value="@Context.Request.Query["searchValue"]" class="form-control" placeholder="Tên nhân viên..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model?.RowCount ?? 0</strong> nhân viên
</div>
<div id="employeeTableContainer">
    <div class="card">
        <div class="card-body p-1">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>Tên nhân viên</th>
                        <th>Ngày sinh</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th class="text-center" style="width:120px;">Trạng thái</th>
                        <th class="text-center" style="width:100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.DataItems != null && Model.DataItems.Count > 0)
                    {
                        foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td class="text-center">
                                    @if (item.IsWorking ?? false)
                                    {
                                        <span class="badge bg-success">Đang làm</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Nghỉ việc</span>
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" onclick="loadPage(@i)">@i</a>
            </li>
        }
    </ul>
</nav>
<script>
    $(document).ready(function () {
        $("#searchForm").on("submit", function (e) {
            e.preventDefault();

            $.ajax({
                url: "@Url.Action("Search", "Employee")",
                type: "POST",
                data: $(this).serialize(),
                success: function (result) {
                    $("#employeeTableContainer").html(result);
                },
                error: function () {
                    alert("An error occurred while processing your request.");
                }
            });
        });
    });
</script>

