@model SV22T1020761.Models.Partner.Supplier
<div class="p-3">
    <h5>B?n có ch?c ch?n mu?n xóa nhŕ cung c?p <strong>@Model.SupplierName</strong>?</h5>
    <form id="formSupplierDelete" method="post" action="~/Supplier/DeleteConfirmed">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SupplierID" value="@Model.SupplierID" />
        <div class="text-end mt-3">
            <button type="submit" class="btn btn-danger">Xóa</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">H?y</button>
        </div>
    </form>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('formSupplierDelete');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var url = form.action;
            var formData = new FormData(form);
            try {
                var res = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: formData
                });
                if (res.ok) {
                    var html = await res.text();
                    document.getElementById('supplierTableContainer').innerHTML = html;
                    var modalEl = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();
                } else {
                    showToast('L?i khi xóa', 'error');
                }
            } catch (err) {
                showToast('L?i khi xóa: ' + err.message, 'error');
            }
        });
    });
</script>