@model SV22T1020761.Models.Supplier
@{
    ViewBag.Title = "Xóa Nhà cung cấp";
}
<h2>Xóa Nhà cung cấp</h2>
<h3>Bạn có chắc chắn muốn xóa nhà cung cấp này?</h3>
<div>
    <h4>@Model.SupplierName</h4>
    <p>@Model.ContactName</p>
    <p>@Model.Address</p>
</div>
<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="SupplierID" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
