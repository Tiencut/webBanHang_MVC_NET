@model PagedResult<SV22T1020761.Models.Supplier>

<table class="table table-bordered table-hover mb-0">
    <thead class="table-secondary">
        <tr>
            <th>TÍn nh‡ cung c?p</th>
            <th>LiÍn h?</th>
            <th>–?a ch?</th>
            <th class="text-center" style="width:100px;">Thao t·c</th>
        </tr>
    </thead>
    <tbody>
        @if (Model?.DataItems != null && Model.DataItems.Count > 0)
        {
            foreach (var item in Model.DataItems)
            {
                <tr>
                    <td>@item.SupplierName</td>
                    <td>@item.ContactName</td>
                    <td>@item.Address</td>
                    <td class="text-center text-nowrap">
                        <a href="#" class="btn btn-sm btn-primary open-modal" data-url="@Url.Action("Form","Supplier", new { id = item.SupplierID })">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="#" class="btn btn-sm btn-danger open-modal" data-url="@Url.Action("Form","Supplier", new { id = item.SupplierID })?delete=true">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center">KhÙng cÛ d? li?u</td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="#" data-page="@i">@i</a>
            </li>
        }
    </ul>
</nav>