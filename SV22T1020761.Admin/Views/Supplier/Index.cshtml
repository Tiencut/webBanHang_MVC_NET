@model IEnumerable<SV22T1020761.Models.Supplier>
@{
    ViewBag.Title = "Danh sách Nhà cung cấp";
}
<h2>Danh sách Nhà cung cấp</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Tên Nhà cung cấp</th>
            <th>Liên hệ</th>
            <th>Địa chỉ</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SupplierName</td>
                <td>@item.ContactName</td>
                <td>@item.Address</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.SupplierID" class="btn btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.SupplierID" class="btn btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>



