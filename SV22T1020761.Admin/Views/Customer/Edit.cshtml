@model SV22T1020761.Models.Partner.Customer
@{
    ViewBag.Title = "Chỉnh sửa Khách hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save me-1"></i> Lưu
    </button>
    <a asp-action="Index" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Hủy
    </a>
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">Chỉnh sửa Khách hàng</h5>
    </div>
    <div class="card-body">
        <form id="formEdit" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CustomerID" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Tên khách hàng <span class="text-danger">*</span></label>
                    <input asp-for="CustomerName" class="form-control" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Tên giao dịch</label>
                    <input asp-for="ContactName" class="form-control" />
                    <span asp-validation-for="ContactName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Điện thoại</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Tỉnh / Thành</label>
                    <input asp-for="Province" class="form-control" />
                    <span asp-validation-for="Province" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Trạng thái</label>
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsLocked" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Khóa tài khoản</label>
                    </div>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-1">Hủy</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
