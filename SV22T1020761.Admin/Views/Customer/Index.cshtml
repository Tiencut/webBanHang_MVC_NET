@model SV22T1020761.Models.Common.PagedResult<SV22T1020761.Models.Partner.Customer>
@{
    ViewBag.Title = "Quản lý Khách hàng";
}
@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Customer/Index">
            <div class="input-group">
                <input type="text" name="searchValue" value="@Context.Request.Query["searchValue"]" class="form-control" placeholder="Tên khách hàng..." autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model?.RowCount ?? 0</strong> khách hàng
</div>
<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.DataItems != null && Model.DataItems.Count > 0)
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.CustomerName</td>
                            <td>@item.ContactName</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td>@item.Province</td>
                            <td class="text-center">
                                @if (item.IsLocked ?? false)
                                {
                                    <span class="badge bg-danger">Khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mt-3">
        @for (int i = 1; i <= Model?.PageCount; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="?page=@i&searchValue=@Context.Request.Query["searchValue"]">@i</a>
            </li>
        }
    </ul>
</nav>

<script>
    $(document).ready(function () {
        $("#searchForm").on("submit", function (e) {
            e.preventDefault();

            $.ajax({
                url: "@Url.Action("Search", "Customer")",
                type: "POST",
                data: $(this).serialize(),
                success: function (result) {
                    $("#customerTableContainer").html(result);
                },
                error: function () {
                    alert("An error occurred while processing your request.");
                }
            });
        });
    });
</script>

<div>
    <form id="searchForm">
        <input type="text" name="SearchValue" placeholder="Search..." />
        <button type="submit">Search</button>
    </form>
</div>

<div id="customerTableContainer">
    @Html.Partial("_CustomerTable", Model)
</div>
