<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>LiteCommerce</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">    
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />    
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        /* Toast position */
        .app-toast-container { position: fixed; top: 1rem; right: 1rem; z-index: 2000; }
    </style>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open bg-body-tertiary">
    <div class="app-wrapper">
        @await Html.PartialAsync("_Header")
        @await Html.PartialAsync("_Sidebar")        
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-4">
                            <h5 class="mb-0">@ViewBag.Title</h5>
                        </div>
                        <div class="col-sm-8">
                            <div class="input-group d-flex justify-content-end">
                                @await RenderSectionAsync("PageToolBar", required: false)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="app-content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </main>
        @await Html.PartialAsync("_Footer")        
    </div>
    <button id="scrollToTop" onclick="window.scrollTo(0,0)">
        <i class="bi bi-arrow-up-circle"></i>
    </button>
    <div class="modal fade" id="dialogModal" tabindex="-1" aria-hidden="true" style="display:none;">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">                
            </div>
        </div>
    </div>

    <!-- Toast container -->
    <div class="app-toast-container">
        <div id="appToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <strong class="me-auto" id="appToastTitle">Thông báo</strong>
                <small class="text-muted"></small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="appToastBody"></div>
        </div>
    </div>

    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/l10n/vn.js"></script>    
    <script src="~/lib/autonumeric/autonumeric.js"></script>    
    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/lib/adminlte/js/adminlte.js"></script>
    <script src="~/js/site.js"></script>
    <script>
        function showToast(message, type = 'info') {
            var toastEl = document.getElementById('appToast');
            document.getElementById('appToastBody').innerHTML = message;
            var title = document.getElementById('appToastTitle');
            title.innerText = type === 'success' ? 'Thành công' : (type === 'error' ? 'Lỗi' : 'Thông báo');
            toastEl.classList.remove('bg-success','bg-danger','bg-info');
            if (type === 'success') toastEl.classList.add('bg-success');
            if (type === 'error') toastEl.classList.add('bg-danger');
            if (type === 'info') toastEl.classList.add('bg-info');
            var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
            toast.show();
        }

        document.addEventListener("DOMContentLoaded", function () {            
            flatpickr(".date-picker", {
                dateFormat: "d/m/Y",
                locale: "vn",
                allowInput: false
            });
            document.querySelectorAll(".money-input").forEach(element => {
                new AutoNumeric(element, {
                    digitGroupSeparator: '.',
                    decimalCharacter: ',',
                    decimalPlaces: 0,
                    unformatOnSubmit: true
                });
            });
            document.querySelectorAll(".open-modal").forEach(element => {                
                 element.addEventListener("click", function (e) {                    
                    openModal(e, this);
                });
            });

            // Show TempData messages as toast if present
            var success = '@(TempData["Success"] ?? "")';
            var error = '@(TempData["Error"] ?? "")';
            if (success) showToast(success, 'success');
            if (error) showToast(error, 'error');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>